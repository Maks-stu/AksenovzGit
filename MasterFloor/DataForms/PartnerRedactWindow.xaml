<Window x:Class="MasterFloor.DataForms.PartnerRedactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasterFloor.DataForms"
        mc:Ignorable="d"
        Title="PartnerRedactWindow" Height="500" Width="700">
    <Grid>
        <Grid Margin="10, 10, 10, 10">
            <Grid Margin="10, 10, 10, 10">
                <Grid Margin="10" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="0" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="Тип:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <ComboBox x:Name="Partner_Type_CB" Grid.Column="1">
                            <ComboBoxItem Content="ИП"/>
                            <ComboBoxItem Content="КФЛ"/>
                            <ComboBoxItem Content="ХТ"/>
                            <ComboBoxItem Content="ХО"/>
                            <ComboBoxItem Content="ООО"/>
                            <ComboBoxItem Content="АО/НАО"/>
                            <ComboBoxItem Content="ПАО"/>
                            <ComboBoxItem Content="ХП"/>
                            <ComboBoxItem Content="УП"/>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="0" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="Наименование:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBox x:Name="Partner_Name_TB" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="1" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="Юр. адрес:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBox x:Name="Partner_Legal_Address_TB" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="1" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="ИНН:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBox x:Name="Partner_INN_TB" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="2" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="Директор:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBox x:Name="Partner_Director_Name_TB" Text="(Фамилия + инициалы)" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="Телефон:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBox x:Name="Partner_Phone_TB" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="3" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="E-mail:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBox x:Name="Partner_Email_TB" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="3" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="Логотип:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <Button x:Name="Partner_Logo_B" Click="Partner_Logo_Choosing" Margin="15, 10" Content="Выберите файл..." Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10"  Grid.Row="4" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock TextWrapping="Wrap" Margin="10" Text="Рейтинг:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBox x:Name="Partner_Rating_TB" Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="10, 10, 10, 10" Grid.Row="4" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="accept_btn" Content="Добавить" HorizontalAlignment="Center" VerticalAlignment="Center" Click="accept_btn_Click" Grid.Column="0"/>
                        <Button x:Name="reject_btn" Content="Отмена" HorizontalAlignment="Center" VerticalAlignment="Center" Click="reject_btn_Click" Grid.Column="1"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
