<Window x:Class="MasterFloor.DataForms.ProductionRedactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasterFloor.DataForms"
        mc:Ignorable="d"
        Title="ProductionRedactWindow" Height="450" Width="1200">
    <Grid>
        <Grid Margin="10, 10, 10, 10">
            <Grid Margin="10, 10, 10, 10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="0" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Артикль:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Article_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="0" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Наименование:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Name_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="0" Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Описание:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Description_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="1" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Фото:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <Button x:Name="Production_Photo_B" Click="Production_Logo_Choosing" Margin="15, 10" Content="Выберите файл..." Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="1" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Масса нетто:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Net_Weight_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="1" Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Масса брутто:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Gross_Weight_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="2" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Длинна:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Length_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Ширина:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Width_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="2" Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Высота:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Height_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="3" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Минимальная цена:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Min_Partner_Price_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="3" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Сертификат качества:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Quality_Certificate_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="3" Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Номер ГОСТа:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Standard_Number_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="4" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="10" Text="Цена:" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="0"/>
                    <TextBox x:Name="Production_Cost_Price_TB" Grid.Column="1"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="4" Grid.Column="1">
                    <Button x:Name="accept_btn" Content="Добавить" HorizontalAlignment="Center" VerticalAlignment="Center" Click="accept_btn_Click"/>
                </Grid>
                <Grid Margin="10, 10, 10, 10"  Grid.Row="4" Grid.Column="2">
                    <Button x:Name="reject_btn" Content="Отмена" HorizontalAlignment="Center" VerticalAlignment="Center" Click="reject_btn_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
