<Window x:Class="MasterFloor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasterFloor"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="1200">
    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="10" Grid.Row="0">
                <Menu x:Name="Menu" VerticalAlignment="Center">
                    <MenuItem Header="Файл">
                        <MenuItem Header="Сохранить Excel">
                            <MenuItem Header="Все сразу" Click="ToExcel" CommandParameter="0"/>
                            <MenuItem Header="Партнеры" Click="ToExcel" CommandParameter="1"/>
                            <MenuItem Header="История покупок" Click="ToExcel" CommandParameter="2"/>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="Резервное копирование">
                        <MenuItem Header="Сохранить">
                            <MenuItem Header="BIN" Click="Save"/>
                            <MenuItem Header="Excel" Click="ExcelSave"/>
                        </MenuItem>
                        <MenuItem Header="Загрузить">
                            <MenuItem Header="BIN" Click="Load"/>
                            <MenuItem Header="Excel" Click="ExcelLoad"/>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="Продукция">
                        <MenuItem Header="Добавить" Click="AddProduction"/>
                        <MenuItem Header="Изменить" Click="RedactProduction"/>
                        <MenuItem Header="Удалить" Click="DeleteProduction"/>
                    </MenuItem>
                    <TextBox x:Name="Source_TB" Width="100" HorizontalAlignment="Left" VerticalAlignment="Center" TextChanged="Source_TB_TextChanged"/>
                </Menu>
            </Grid>
            <Grid Margin="10" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="2*" MaxWidth="800"/>
                </Grid.ColumnDefinitions>
                <Grid Margin="10, 10, 10, 10" Grid.Column="0">
                    <ListBox x:Name="Partners_LB" Padding="10" SelectionChanged="Partners_LB_Selected">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5, 5, 35, 5" Height="110" VerticalAlignment="Center" 
                                        BorderBrush="Black" BorderThickness="0.5" HorizontalAlignment="Stretch" 
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                    <StackPanel Margin="5" HorizontalAlignment="Stretch">
                                        <Grid Margin="5" HorizontalAlignment="Stretch">
                                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                                <TextBlock FontSize="14" Padding="5, 5, 0, 5" Text="{Binding Path=Type}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                <Label Content="|"/>
                                                <TextBlock FontSize="14" Padding="0, 5, 5, 5" Text="{Binding Path=Name}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                            </StackPanel>
                                            <TextBlock FontSize="12" Padding="5" Text="{Binding Path=Discount, StringFormat={}{0} %}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                        </Grid>
                                        <StackPanel Orientation="Vertical" Margin="5" HorizontalAlignment="Stretch">
                                            <TextBlock FontSize="12" Text="{Binding Path=DirectorName, StringFormat={}Директор {0}}" HorizontalAlignment="Left" />
                                            <TextBlock FontSize="12" Text="{Binding Path=Phone}" HorizontalAlignment="Left" />
                                            <TextBlock FontSize="12" Text="{Binding Path=Rating, StringFormat={}Рейтинг: {0}}" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Добавить" Click="AddPartner"/>
                                <MenuItem Header="Редактировать" Click="RedactPartner"/>
                                <MenuItem Header="Удалить" Click="DeletePartner"/>
                                <MenuItem Header="Добавить заказ" Click="AddProductSaleSelected"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </Grid>
                <Grid Margin="10" Grid.Column="1">
                    <DataGrid x:Name="ProductSales_Table" CanUserSortColumns="True" Margin="10, 10, 10, 10" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" IsReadOnly="True" RowBackground="Azure" AlternatingRowBackground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*" Header="Дата" Binding="{Binding Path=Date}"/>
                            <DataGridTextColumn Width="*" Header="Количество" Binding="{Binding Path=Count}"/>
                            <DataGridTextColumn Width="*" Header="Продукция" Binding="{Binding Path=Production}"/>
                            <DataGridTextColumn Width="*" Header="Итоговая сумма" Binding="{Binding Path=TotalPrice, StringFormat={}{0} ₽}"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Добавить" Click="AddProductSale"/>
                                <MenuItem Header="Редактировать" Click="RedactProductSale"/>
                                <MenuItem Header="Удалить" Click="DeleteProductSale"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>